# =========================
    # KIT ADMIN
# =========================
command /kitadmin [<number>] [<number>] [<text>]:
  permission: op
  permission message: {@prefix}&cVocê não tem permissão para usar isto.
  trigger:
    if arg-1 is not set:
      send "&c/kitadmin <kit> <distancia> <all/vazio>" to player
      stop
    if arg-2 is not set:
      send "&c/kitadmin <kit> <distancia> <all/vazio>" to player
      stop

    #Define os itens.
    clear {_items::*}
    if arg-1 = 1:
      set {_bau} to block at location(-23,60,-46, world named "staff")
      set {_inv} to inventory of {_bau}
      
      loop all items in {_inv}:
        if loop-value is not air:
          add loop-value to {_items::*}

    else if arg-1 = 2:
      set {_bau} to block at location(-26,60,-46, world named "staff")
      set {_inv} to inventory of {_bau}

      loop all items in {_inv}:
        if loop-value is not air:
          add loop-value to {_items::*}

    else if arg-1 = 3:
      set {_bau} to block at location(-29,60,-46, world named "staff")
      set {_inv} to inventory of {_bau}

      loop all items in {_inv}:
        if loop-value is not air:
          add loop-value to {_items::*}

    else:
      send "&cEsse kit não existe" to player
      stop
    
    #Dá o kit para os players próximos
    set {_count} to 0
    loop all players in radius arg-2 around player:

      if arg-3 is not "all":
        if loop-player is not player:
          loop {_items::*}:
            if loop-player-1 has space for loop-value-2:
              give loop-value-2 to loop-player-1
            else:
              drop loop-value-2 at location of loop-player-1

          play sound "block.smithing_table.use" to loop-player
          send "&aVocê recebeu um kit de um admin!" to loop-player
          add 1 to {_count}
      else:
        loop {_items::*}:
          if loop-player-1 has space for loop-value-2:
            give loop-value-2 to loop-player-1
          else:
            drop loop-value-2 at location of loop-player-1

        play sound "block.smithing_table.use" at location of loop-player
        send "&aVocê recebeu um kit de um admin!" to loop-player
        add 1 to {_count}

    send "&e%{_count}% &aKits distribuídos" to player

on tab complete of "/kitadmin":
 set tab completions for position 1 to "1" and "2" and "3"
 set tab completions for position 2 to "distance"
 set tab completions for position 3 to "all"

