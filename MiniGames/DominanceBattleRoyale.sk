function atualizabarreira():

 #Identifica quantos players estão no jogo
 set {_qtdplayers} to 0
 loop {eventoDominance::players::*}:
  if loop-value is offline player:
   if {eventoDominance::players::%loop-value%::ingame} is true:
    add 1 to {_qtdplayers}
  
 #calcula tamanho da barreira
 clear {_tamanho}
 if {_qtdplayers} = 1:
  set {_tamanho} to {_qtdplayers} * 1000
 else:
  set {_tamanho} to {_qtdplayers} * 25

 set {eventoDominance::barreira} to {_tamanho} / 2
 execute console command "execute in minecraft:dominancegame run mv worldborder set %{_tamanho}% -1 %{@dynamicworld}%"


function aleatorizaspawn():
 clear {_spawnsvalidos::*}
 set {_barreira} to {eventoDominance::barreira}
 #procura por spawns dentro da barreira
 loop {eventoDominance::spawnspots::*}:
  set {_loc} to loop-value
  set {_x} to round(x-coordinate of {_loc})
  set {_z} to round(z-coordinate of {_loc})

  if abs({_x}) > {_barreira}:
   continue
  if abs({_z}) > {_barreira}:
   continue
  add {_loc} to {_spawnsvalidos::*}

 set {_maxspawns} to size of {_spawnsvalidos::*}
 if {_maxspawns} < 2: #Precisa haver pelomenos 2 spawns
  loop all players in world {@modelworld}:
   send "&cO jogo não pôde ser iniciado pois não há jogadores o suficiente!" to loop-player
  send "&cEvento Dominance não pôde ser iniciado pois não há jogadores o suficiente!" to console
  
  wait 2 seconds
  execute console command "dominance end"
  stop

 set {_loops} to min({_maxspawns}, 10)

 clear {_selectedspawns::*}
 loop {_loops} times:
  #Escolhe spawn aleatório
  set {_escolha} to random element out of {_spawnsvalidos::*}
  if {_escolha} is set:
   add {_escolha} to {_selectedspawns::*}
   remove {_escolha} from {_spawnsvalidos::*}

 set {_tpcount} to 1   
 #Teleporta player 
 loop {eventoDominance::players::*}:
  if {eventoDominance::players::%loop-value%::ingame} is true:
   if {eventoDominance::players::%loop-value%::teleported} is not set:

    set {eventoDominance::players::%loop-value%::teleported} to true
    set {_destino} to {_selectedspawns::%{_tpcount}%}
    teleport loop-value to {_destino}

    add 1 to {_tpcount}
    if {_tpcount} > {_loops}:
     set {_tpcount} to 1

function avisaplayers(tempo: number):
 loop all players:
  #Avisa players fora do evento
  #Avisa players dentro do evento
  if world of loop-player is {@modelworld}:
   send title "" to loop-player
   send subtitle "&aComeça em &b%{_tempo}%&as!" to loop-player

function DominanceTempoWaiting(tempo: number):
 set {_contador} to {_tempo}

 # Contagem regressiva
 while {eventoDominance::State} is "waiting":
  if {_contador} = 40:
   avisaplayers({_contador})
  if {_contador} = 30:
   avisaplayers({_contador})
  if {_contador} = 20:
   avisaplayers({_contador})
  if {_contador} = 10:
   avisaplayers({_contador})
  if {_contador} <= 5:
   avisaplayers({_contador})

  wait 1 second
  subtract 1 from {_contador}

  #INICIA O JOGO
  if {_contador} <= 0:
   set {eventoDominance::State} to "ongoing"
   atualizabarreira()
   DominanceTempoOngoing(2400) #segundos - 40 mins #######################################
   stop loop

function DominanceTempoOngoing(tempo: number):
 aleatorizaspawn()
 set {_contador} to {_tempo}
 
function RestauraPlayerEndGame(p: player):
 #Restaurar o player
 #Inventário
 clear {_p}'s inventory
 loop {eventoDominance::players::%{_p}%::playersaveinv::*}:
  set {_slot} to loop-index parsed as number
  set slot {_slot} of {_p} to loop-value
 
 set helmet of {_p} to {eventoDominance::players::%{_p}%::playersaveinv::helmet}
 set chestplate of {_p} to {eventoDominance::players::%{_p}%::playersaveinv::chestplate}
 set leggings of {_p} to {eventoDominance::players::%{_p}%::playersaveinv::leggings}
 set boots of {_p} to {eventoDominance::players::%{_p}%::playersaveinv::boots}
 set off hand of {_p} to {eventoDominance::players::%{_p}%::playersaveinv::offhand}

 #Nível e exp
 set level of {_p} to {eventoDominance::players::%{_p}%::playersaveexp::level}
 set experience of {_p} to {eventoDominance::players::%{_p}%::playersaveexp::exp}
 #Gamemode survival
 set gamemode of {_p} to survival

 #Limpar Flags do player
 delete {eventoDominance::players::%{_p}%}
 delete {eventoDominance::players::%{_p}%::*}

#Iniciar Minigame
command /Dominance [<text>]:
 trigger:
  #Entrar no Minigame
  if arg-1 is not set:
   if {eventoDominance::players::%player%::ingame} is true:
    send "&cVocê já entrou no jogo!"
    stop
   if {eventoDominance::players::%player%::ingame} is false:
    send "&cAguarde o próximo jogo!"
    stop

   if {eventoDominance::State} is "waiting":
    # Salva localização
    set {eventoDominance::players::%player%::playersaveloc} to location of player
    
    # Salva inventário e xp
    loop 36 times:
     set {_slot} to loop-number -1
     set {eventoDominance::players::%player%::playersaveinv::%{_slot}%} to slot {_slot} of player's inventory

    set {eventoDominance::players::%player%::playersaveinv::helmet} to helmet of player
    set {eventoDominance::players::%player%::playersaveinv::chestplate} to chestplate of player
    set {eventoDominance::players::%player%::playersaveinv::leggings} to leggings of player
    set {eventoDominance::players::%player%::playersaveinv::boots} to boots of player
    set {eventoDominance::players::%player%::playersaveinv::offhand} to off hand of player
    
    set {eventoDominance::players::%player%::playersaveexp::level} to level of player
    set {eventoDominance::players::%player%::playersaveexp::exp} to experience of player
    set {eventoDominance::players::%player%} to player
    set {eventoDominance::players::%player%::ingame} to true
    wait 2 tick

    clear player's inventory
    clear level of player
    clear experience of player
    clear potion effects of player
    give player spyglass
    teleport player to location(0,117,0, world "dominancemodel")

   else if {eventoDominance::State} is not set:
    send "&co evento Dominance não está em atividade." to player

   else if {eventoDominance::State} is not "waiting":
    send "&cO evento já começou!" to player

  # Comandos admnistrativos ############################################################
  if arg-1 is "start": #-Começa evento
   if player is set:
    if player is not op:
     send "&cVocê não tem permissão!" to player
     stop

   if {eventoDominance::State} is not set:
    send "&aEvento iniciado" to player
    send "&aEvento iniciado" to console
    set {eventoDominance::State} to "waiting"
    DominanceTempoWaiting(60)
    criarmapa()

   else:
    send "&cO evento já foi iniciado" to player


  if arg-1 is "end": #-Termina evento
   if player is set:
    if player is not op:
     send "&cVocê não tem permissão!" to player
     stop

   if {eventoDominance::State} is set:
    loop all players:
     if world of loop-player is {@dynamicworld} or {@modelworld}:
      # Teleporta player
      if {eventoDominance::players::%loop-player%::playersaveloc} is set:
       teleport loop-player to {eventoDominance::players::%loop-player%::playersaveloc}

       # Restaurar Player
       RestauraPlayerEndGame(loop-player)

      else:
       teleport loop-player to spawn point of world "world"
     
    execute console command "mv delete %{@dynamicworld}% --remove-players"

    #Limpar flags #Lembrar depois de identificar se o player saiu do jogo, e nao voltou, para nao limpar os dados deles até ele voltar
    delete {eventoDominance::*}

    send "&cEvento terminado" to player
    send "&cEvento terminado" to console
   else:
    send "&cNão há evento em execução" to player
 

    

on tab complete of "/Dominance":
 if player is op:
  set tab completions for position 1 to "start" and "end"

#teste
command /Dominancedebug:
 trigger:
  give player {eventoDominance::LootKeys::*}
  send {eventoDominance::players::%player%} to player
  send {eventoDominance::players::%player%::playersaveloc} to player
  #send {eventoDominance::players::%player%::playersaveinv::*} to player