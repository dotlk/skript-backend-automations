##################
# LootKeys Actions
##################
#Funções
#Verifica se as lootkeys são válidas
function IsLootkeyFerro(i: item) :: boolean: 
 if {_i} is cookie:
  if custom model data of {_i} is 9001:
   return true
    
 return false
function IsLootkeyOuro(i: item) :: boolean: 
 if {_i} is cookie:
  if custom model data of {_i} is 9002:
   return true

 return false
function IsLootkeyDiamante(i: item) :: boolean: 
 if {_i} is cookie:
  if custom model data of {_i} is 9003:
   return true
    
 return false
function IsLootkeyEsmeralda(i: item) :: boolean: 
 if {_i} is cookie:
  if custom model data of {_i} is 9004:
   return true
    
 return false
function IsLootkeyNetherite(i: item) :: boolean: 
 if {_i} is cookie:
  if custom model data of {_i} is 9005:
   return true
    
 return false

function RandomDropLootKey(rarityRDL: number, p: player):
 set {_container::5} to block at location(-23,64,-47, world named "staff") #Netherite
 set {_container::4} to block at location(-33,64,-44, world named "staff") #Esmeralda
 set {_container::3} to block at location(-26,64,-47, world named "staff") #Diamante
 set {_container::2} to block at location(-29,64,-47, world named "staff") #Ouro
 set {_container::1} to block at location(-32,64,-47, world named "staff") #Ferro
 
 #define a lista de items
 clear {_items::*}
 loop {_rarityRDL} times:
  set {_ContainerAtual} to loop-number

  loop all items in {_container::%{_ContainerAtual}%}:
   if loop-value-2 is not air:
    add loop-value-2 to {_items::*}
    set {_index} to size of {_items::*}
    #Define a raridade do item
    if {_ContainerAtual} = 1:
     set {_items::%{_index}%::particle} to "ferro"
    if {_ContainerAtual} = 2:
     set {_items::%{_index}%::particle} to "ouro"
    if {_ContainerAtual} = 3:
     set {_items::%{_index}%::particle} to "diamante"
    if {_ContainerAtual} = 4:
     set {_items::%{_index}%::particle} to "esmeralda"
    if {_ContainerAtual} = 5:
     set {_items::%{_index}%::particle} to "netherite"

 #Dropa itens
 loop {_items::*}:
  set {_itemindex} to loop-index
  set {_itemparticle} to {_items::%{_itemindex}%::particle}

  drop loop-value at location of {_p}

  clear {_itementity}
  if item of last dropped item is loop-value:
   set {_itementity} to last dropped item

  run section in background with {_itementity}, {_itemparticle}: #Skript-reflect dependent
   loop 20 times:
    if {_itementity} is alive:
     if {_itemparticle} is "ferro":
      make 10 of firework particle at location of {_itementity} with offset vector(0.05, 0.05, 0.05) with extra 0.05 
     else if {_itemparticle} is "ouro":
      make 10 of small flame particle at location of {_itementity} with offset vector(0.05, 0.05, 0.05) with extra 0.05 
     else if {_itemparticle} is "diamante":
      make 10 of soul fire flame particle at location of {_itementity} with offset vector(0.05, 0.05, 0.05) with extra 0.05 
     else if {_itemparticle} is "esmeralda":
      make 10 of glow particle at location of {_itementity} with offset vector(0.05, 0.05, 0.05) with extra 0.05
     else if {_itemparticle} is "netherite":
      make 10 of dragon breath particle at location of {_itementity} with offset vector(0.05, 0.05, 0.05) with extra 0.05 
     wait 1 tick
    else:
     stop loop

#Eventos
On eat of cookie:
 if IsLootkeyFerro(event-item) is true:#FERRO
  RandomDropLootKey(1, event-player)

 if IsLootkeyOuro(event-item) is true:#OURO
  loop 2 times:
   RandomDropLootKey(loop-number, event-player)

 if IsLootkeyDiamante(event-item) is true:#DIAMANTE
  loop 3 times:
   RandomDropLootKey(loop-number, event-player)

 if IsLootkeyEsmeralda(event-item) is true:#ESMERALDA
  loop 4 times:
   RandomDropLootKey(loop-number, event-player)

 if IsLootkeyNetherite(event-item) is true:#NETHERITE
  loop 5 times:
   send "netherite" to player
   RandomDropLootKey(loop-number, event-player)


#####################################
#         MINIGAME
#####################################
options:
  modelworld: "DominanceModel" #{@modelworld}
  dynamicworld: "Dominancegame" #{@dynamicworld}
  
#Funções
function criarmapa():
 execute console command "mv clone %{@modelworld}% %{@dynamicworld}%"
 execute console command "execute in minecraft:dominancegame run fill 30 116 30 -30 122 -30 air"
 execute console command "execute in minecraft:dominancegame run mv gamerule set doDaylightCycle true %{@dynamicworld}%"
 
 #Custom items
 set {eventoDominance::LootKeys::ferro} to glowing cookie named "&7&lLoot Signal" with lore "&7Raridade: &7&lFerro"
 set max stack size of {eventoDominance::LootKeys::ferro} to 99
 set custom model data of {eventoDominance::LootKeys::ferro} to 9001
 apply food component to {eventoDominance::LootKeys::ferro}:
  nutrition: 0
  saturation: 3
  can_always_eat: true

 set {eventoDominance::LootKeys::ouro} to glowing cookie named "&6&lLoot Signal" with lore "&7Raridade: &6&lOuro"
 set max stack size of {eventoDominance::LootKeys::ouro} to 99
 set custom model data of {eventoDominance::LootKeys::ouro} to 9002
 apply food component to {eventoDominance::LootKeys::ouro}:
  nutrition: 0
  saturation: 3
  can_always_eat: true

 set {eventoDominance::LootKeys::diamante} to glowing cookie named "&b&lLoot Signal" with lore "&7Raridade: &b&lDiamante"
 set max stack size of {eventoDominance::LootKeys::diamante} to 99
